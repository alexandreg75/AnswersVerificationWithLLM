{
  "name": "grader-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,wrk -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:worker\"",
    "dev:no-worker": "concurrently -n api,web -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "build": "npm -ws run build",
    "start": "npm -ws --if-present run start",
    "verify": "bash scripts/verify.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
